# =============================================================================
# AA2000 Connect CRM — Environment Configuration
# =============================================================================
# Copy this file to .env for local development (never commit .env).
# All variables are prefixed with VITE_ for Vite exposure to the client.
# =============================================================================

# --- Database (Supabase) ----------------------------------------------------
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- AI / LLM Providers -----------------------------------------------------
# Gemini (used in knowledge-base & product-search pages)
VITE_GEMINI_API_KEY=your-gemini-api-key

# Groq Cloud (used in AI Knowledge assistant)
VITE_GROQ_API_KEY=your-groq-api-key

# Mistral AI (referenced in AI Agents UI)
VITE_MISTRAL_API_KEY=your-mistral-api-key

# --- Messaging / Communication ----------------------------------------------
VITE_VIBER_TOKEN=your-viber-token
VITE_WHATSAPP_TOKEN=your-whatsapp-token
VITE_SMS_GATEWAY_KEY=your-sms-gateway-key
VITE_SMTP_PASSWORD=your-smtp-password

# --- Social / Ad Platforms --------------------------------------------------
VITE_TIKTOK_SECRET=your-tiktok-secret
VITE_META_ACCESS_TOKEN=your-meta-access-token

# --- Website / Customer Engagement ------------------------------------------
VITE_WEBSITE_API_KEY=your-website-api-key
