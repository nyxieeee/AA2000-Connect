# AA2000 Connect — System Integration Secrets
# Configure these environment variables to activate connected apps on the Admin Dashboard.

# ─── Core AI Engine & Providers
# Google Gemini API key (Supports native Search Grounding & Vision)
VITE_GEMINI_API_KEY=REDACTED_KEY

# Groq Developer API key (Powers Llama 3.1, GPT-OSS, and Qwen)
VITE_GROQ_API_KEY=

# Mistral Developer API key (Powers Open Mistral Nemo agent logic)
VITE_MISTRAL_API_KEY=

# ─── Chat & Messenger Channels
# Viber Auth Token for support bot
VITE_VIBER_TOKEN=

# WhatsApp Business Access Token (Meta API)
VITE_WHATSAPP_TOKEN=

# ─── Social Ads Lead Sync
# TikTok Developer App Secret
VITE_TIKTOK_SECRET=

# Facebook & Instagram Page Access Token
VITE_META_ACCESS_TOKEN=

# ─── Messaging & Web Channels
# SMS Gateway Provider API Key
VITE_SMS_GATEWAY_KEY=

# Website API Key (Client Widget Inquiry Forms)
VITE_WEBSITE_API_KEY=

# ─── SMTP Email Gateway
# SMTP Mail Delivery Password / Token
VITE_SMTP_PASSWORD=
